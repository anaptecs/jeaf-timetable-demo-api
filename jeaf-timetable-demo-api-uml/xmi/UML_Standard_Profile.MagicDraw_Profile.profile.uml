0 30 20 2d 31 20 30 20 32 33 2e 35 29 22 3e d a 9 9 9 9 3c 73 74 6f 70 20 20 6f 66 66 73 65 74 3d 22 30 22 20 73 74 79 6c 65 3d 22 73 74 6f 70 2d 63 6f 6c 6f 72 3a 23 46 46 46 46 46 46 22 2f 3e d a 9 9 9 9 3c 73 74 6f 70 20 20 6f 66 66 73 65 74 3d 22 31 22 20 73 74 79 6c 65 3d 22 73 74 6f 70 2d 63 6f 6c 6f 72 3a 23 42 32 42 32 42 32 22 2f 3e d a 9 9 9 3c 2f 6c 69 6e 65 61 72 47 72 61 64 69 65 6e 74 3e d a 9 9 9 3c 72 65 63 74 20 78 3d 22 32 2e 32 22 20 79 3d 22 37 2e 34 22 20 73 74 79 6c 65 3d 22 66 69 6c 6c 3a 75 72 6c 28 23 53 56 47 49 44 5f 31 5f 29 3b 73 74 72 6f 6b 65 3a 23 30 31 38 34 38 34 3b 73 74 72 6f 6b 65 2d 6d 69 74 65 72 6c 69 6d 69 74 3a 31 30 3b 22 20 77 69 64 74 68 3d 22 31 39 2e 36 22 20 68 65 69 67 68 74 3d 22 31 31 2e 39 22 2f 3e d a 9 9 3c 2f 67 3e d a 9 3c 2f 67 3e d a 3c 2f 73 77 69 74 63 68 3e a 3c 2f 73 76 67 3e d a " location="D:\Dokumentai\#Icons\2015-11-24 Ikonos is Aurimo\images\images\stereotype fileview.svg" format="SVG">
