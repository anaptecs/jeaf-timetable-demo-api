se&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;true&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;argument xsi:type=&quot;booleanExpressionSpecification&quot; value=&quot;false&quot;/>&#xA;            &lt;expression xsi:type=&quot;interpretElementExpressionSpecification&quot;>&#xA;                &lt;element xsi:type=&quot;elementExpressionSpecification&quot; element=&quot;23beffc3-89e3-4b3f-bb9a-e807872509ae&quot;/>&#xA;            &lt;/expression>&#xA;        &lt;/argument>&#xA;        &lt;expression xsi:type=&quot;makeInlineExpressionSpecification&quot; language=&quot;Groovy&quot;>&#xA;            &lt;parameter name=&quot;arg1&quot; type=&quot;java.lang.Object&quot; ordered=&quot;false&quot; unique=&quot;false&quot; multiple=&quot;false&quot;/>&#xA;            &lt;body>import com.nomagic.uml2.ext.jmi.helpers.StereotypesHelper&#xA;import com.nomagic.uml2.ext.magicdraw.classes.mdkernel.InstanceSpecification&#xA;&#xA;Set set = (HashSet)arg1;&#xA;return set.size()&lt;/body>&#xA;        &lt;/expression>&#xA;    &lt;/value>&#xA;&lt;/unionExpressionSpecification>&#xA;</body>
          </defaultValue>
